# 统一行尾：文本文件用 LF（跨平台一致），二进制文件不做转换
* text=auto eol=lf

# 二进制文件不做行尾转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.mp4 binary
*.webm binary
*.mp3 binary
*.wav binary
*.pdf binary
*.jar binary
*.xdb binary
*.xlsx binary
*.docx binary
