# 【通用】环境变量

#  版本号
VITE_VERSION = 1.0.0

# 端口号
VITE_PORT = 3000

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# 权限模式【 frontend 前端模式 / backend 后端模式 】
# 对接 XuYa-Max，菜单由后端 /system/menu/getRouters 返回，必须使用 backend
VITE_ACCESS_MODE = backend

# 跨域请求时是否携带 Cookie（开启前需确保后端支持）
VITE_WITH_CREDENTIALS = false

# 是否打开路由信息
VITE_OPEN_ROUTE_INFO = false

# 锁屏加密密钥
VITE_LOCK_ENCRYPT_KEY = s3cur3k3y4adpro

# ==================== XuYa-Max 对接配置 ====================
# 页面标题（浏览器 tab 标题后缀，如 "用户管理 - XuYa-Max 后台管理系统"）
VITE_APP_TITLE = XuYa-Max 后台管理系统
# 系统名称（侧边栏 logo / 登录页 / 水印等位置显示的短名称）
VITE_APP_NAME = XuYa-Max
# PC 端客户端授权 id（后端 sys_client 表对应，登录及每个请求必传 clientid 头）
VITE_APP_CLIENT_ID = 'e5cd7e4891bf95d1d19206ce24a7b32e'
# 接口加密开关（需与后端 application.yml 的 api-decrypt.enabled 保持一致）
VITE_APP_ENCRYPT = true
# 接口加密传输 RSA 公钥（前端加密 AES key，后端用对应私钥解密）
VITE_APP_RSA_PUBLIC_KEY = 'MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBgQDvEDuRIOM3oZPWj9Ukoc5pQklR4PFH6/clnjeFqjDLIgDyQvjxhgqAZQA+E9eD6qu6FsXPmK8djcL+nh3cFHz4pX473jDvO3Sve+8yL3VRQ0n2pRgQ2a01MJsy+WwTZCBYWf0VnLRIvANUoWQgy9vz94q7Va44dg7A1/3ICf+xAwIDAQAB'
# 接口响应解密 RSA 私钥（后端用对应公钥加密响应，前端解密）
VITE_APP_RSA_PRIVATE_KEY = ''
# 统一消息推送开关（SSE/WebSocket）
VITE_APP_MESSAGE_ENABLED = true
# 消息推送传输方式 sse / websocket
VITE_APP_MESSAGE_TRANSPORT = 'sse'
# 消息推送路径
VITE_APP_MESSAGE_PATH = '/resource/message'

# 任务调度控制台地址（iframe 内嵌，开发环境填完整地址，生产环境由 Nginx 代理）
VITE_APP_SNAILJOB_ADMIN = 'http://localhost:8800/snail-job'
