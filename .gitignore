######################################################################
# XuYa-Max 根级 .gitignore（统一管理 backend + frontend）
######################################################################

# ===== 编译产物 =====
**/target/
**/build/
**/dist/
**/dist-ssr/
**/.gradle/
**/.out/
**/*.class

# ===== Maven Wrapper（保留 .mvn/wrapper/maven-wrapper.jar，排除其它）=====
# !**/.mvn/wrapper/maven-wrapper.jar

# ===== 依赖目录 =====
**/node_modules/

# ===== 运行日志 =====
**/logs/
*.log

# ===== 前端自动生成文件 =====
XuYa-Max-frontend/src/types/import/auto-imports.d.ts
XuYa-Max-frontend/src/types/import/components.d.ts
XuYa-Max-frontend/.auto-import.json

# ===== 本地环境覆盖 =====
*.local
.env.local
.env.*.local

# ===== IDE =====
.idea/
.vscode/
*.iml
*.iws
*.ipr
*.swp
*~

# ===== STS / Eclipse =====
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.factorypath

# ===== 系统文件 =====
.DS_Store
Thumbs.db
desktop.ini

# ===== 临时文件 =====
*.tmp
*.bak
*.cache

# ===== 上传/测试产物 =====
*.xlsx
!XuYa-Max-backend/script/**/*.xlsx
